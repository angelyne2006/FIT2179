{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 280,
  "title": {
    "text": "Flood Evacuation Events by State (Dec 2024 – May 2025)",
    "subtitle": "Each dot = one evacuation event · Size = number of evacuees",
    "fontSize": 14,
    "subtitleFontSize": 11
  },
  "data": {
    "url": "https://raw.githubusercontent.com/angelyne2006/FIT2179/main/data/malaysia_flood_evacuees_reliefweb.csv"
  },
  "transform": [
    {"filter": "datum.state != 'Multiple States'"}
  ],
  "layer": [
    {
      "mark": {"type": "tick", "color": "#ddd", "thickness": 1, "size": 12},
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "title": null,
          "sort": ["Sarawak", "Sabah", "Johor", "Selangor", "Pahang", "Negeri Sembilan", "Terengganu", "Perak"]
        },
        "x": {
          "aggregate": "mean",
          "field": "evacuees",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {"type": "circle", "opacity": 0.85},
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "title": null,
          "sort": ["Sarawak", "Sabah", "Johor", "Selangor", "Pahang", "Negeri Sembilan", "Terengganu", "Perak"]
        },
        "x": {
          "field": "evacuees",
          "type": "quantitative",
          "title": "Number of Evacuees",
          "axis": {"format": ",", "formatType": "number"}
        },
        "size": {
          "field": "evacuees",
          "type": "quantitative",
          "scale": {"range": [50, 600]},
          "legend": null
        },
        "color": {"value": "#1a3a5c"},
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "evacuees", "type": "quantitative", "title": "Evacuees", "format": ","},
          {"field": "date", "type": "nominal", "title": "Date"},
          {"field": "source", "type": "nominal", "title": "Source"}
        ]
      }
    }
  ]
}